# ─────────────────────────────────────────────────────────
# MenuQR - Environment Variables untuk VPS
# Salin file ini ke .env dan isi nilainya
# ─────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=menuqr
POSTGRES_PASSWORD=ganti_dengan_password_kuat_anda
POSTGRES_DB=menuqr

# ── App ───────────────────────────────────────────────────
# Port yang diekspos ke host (default 3000)
APP_PORT=3000

# URL publik app Anda (pakai domain atau IP VPS)
# Contoh: https://menuqr.yourdomain.com  atau  http://123.456.789.0:3000
NEXT_PUBLIC_APP_URL=http://YOUR_VPS_IP:3000
BETTER_AUTH_URL=http://YOUR_VPS_IP:3000

# Secret untuk better-auth (generate dengan: openssl rand -base64 32)
BETTER_AUTH_SECRET=ganti_dengan_secret_minimal_32_karakter

# ── SMTP / Resend Configuration ───────────────────────────
# Jika memakai Resend.com SMTP:
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=465
# SMTP_USER=resend
# SMTP_PASSWORD=isi_dengan_resend_api_key_anda (e.g. re_...)
# SMTP_FROM=support@menuqr.my.id
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=re_your_api_key
SMTP_FROM=support@menuqr.my.id

# ── MinIO / S3 Configuration ──────────────────────────────
S3_ENDPOINT=https://kendariweb-minio.q00ohl.easypanel.host
S3_BUCKET_NAME=menuqr
S3_ACCESS_KEY=isi_dengan_access_key_minio_anda
S3_SECRET_KEY=isi_dengan_secret_key_minio_anda
S3_REGION=us-east-1
# S3_PUBLIC_URL opsional jika butuh kustomisasi host CDN / public access
# S3_PUBLIC_URL=https://kendariweb-minio.q00ohl.easypanel.host/menuqr
